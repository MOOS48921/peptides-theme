{{ 'peptides-footer.css' | asset_url | stylesheet_tag }}

<footer class="peptides-footer" role="contentinfo">
  <div class="peptides-footer__inner page-width">

    <div class="peptides-footer__columns">

      {%- comment -%} Column 1 – Informatie {%- endcomment -%}
      <div class="peptides-footer__col">
        <h3 class="peptides-footer__heading">INFORMATIE</h3>
        <ul class="peptides-footer__links">
          <li><a href="/pages/over-ons" class="peptides-footer__link">Over ons</a></li>
          <li><a href="/pages/helpcentrum" class="peptides-footer__link">Helpcentrum</a></li>
          <li><a href="/policies/privacy-policy" class="peptides-footer__link">Privacybeleid</a></li>
          <li><a href="/policies/terms-of-service" class="peptides-footer__link">Algemene Voorwaarden</a></li>
        </ul>
      </div>

      {%- comment -%} Column 2 – Bestellen/Ondersteuning {%- endcomment -%}
      <div class="peptides-footer__col">
        <h3 class="peptides-footer__heading">BESTELLEN/ONDERSTEUNING</h3>
        <ul class="peptides-footer__links">
          <li><a href="/pages/verzending" class="peptides-footer__link">Verzending</a></li>
          <li><a href="/pages/retourzendingen" class="peptides-footer__link">Retourzendingen</a></li>
          <li><a href="/pages/calculator" class="peptides-footer__link">Calculator</a></li>
        </ul>
      </div>

      {%- comment -%} Column 3 – Mijn Account {%- endcomment -%}
      <div class="peptides-footer__col">
        <h3 class="peptides-footer__heading">MIJN ACCOUNT</h3>
        <ul class="peptides-footer__links">
          <li><a href="/account" class="peptides-footer__link">Mijn Account</a></li>
          <li><a href="/account/orders" class="peptides-footer__link">Bestellingen</a></li>
          <li><a href="/cart" class="peptides-footer__link">Winkelwagen</a></li>
        </ul>
      </div>

      {%- comment -%} Column 4 – Follow Us {%- endcomment -%}
      <div class="peptides-footer__col">
        <h3 class="peptides-footer__heading">FOLLOW US</h3>
        <div class="peptides-footer__socials">
          <a href="#" class="peptides-footer__social-btn" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
              <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" class="peptides-footer__social-btn" aria-label="TikTok" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#" class="peptides-footer__social-btn" aria-label="Telegram" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.833.941z"/>
            </svg>
          </a>
        </div>
        <div class="peptides-footer__lang">
          <span class="peptides-footer__lang-flag" aria-hidden="true">🇳🇱</span>
          <select class="peptides-footer__lang-select" aria-label="Taal selecteren">
            <option value="nl" selected>Nederlands</option>
            <option value="en">English</option>
            <option value="de">Deutsch</option>
            <option value="fr">Français</option>
          </select>
          <span class="peptides-footer__lang-caret" aria-hidden="true">
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </div>

    </div>

    {%- comment -%} Samenwerking row {%- endcomment -%}
    <div class="peptides-footer__samenwerking">
      <h4 class="peptides-footer__samenwerking-heading">SAMENWERKING</h4>
      <ul class="peptides-footer__links peptides-footer__links--inline">
        <li><a href="/pages/groothandel" class="peptides-footer__link">Groothandelsaankoop</a></li>
        <li><a href="/pages/partner" class="peptides-footer__link">Word Partner</a></li>
      </ul>
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="peptides-footer__bottom">
      <div class="peptides-footer__payment-icons">
        <img src="https://cdn.shopify.com/s/files/1/1035/2767/8294/files/images.png?v=1781102072" alt="Visa" class="peptides-footer__pay-img">
        <img src="https://cdn.shopify.com/s/files/1/1035/2767/8294/files/Mastercard_2019_logo.svg?v=1781102106" alt="Mastercard" class="peptides-footer__pay-img">
        <img src="https://cdn.shopify.com/s/files/1/1035/2767/8294/files/apple-pay-og-twitter.jpg?v=1781102058" alt="Apple Pay" class="peptides-footer__pay-img peptides-footer__pay-img--dark">
        <img src="https://cdn.shopify.com/s/files/1/1035/2767/8294/files/ideal-logo-seo.png?v=1781101930" alt="iDEAL" class="peptides-footer__pay-img">
        <img src="https://cdn.shopify.com/s/files/1/1035/2767/8294/files/bancontact-krijgt-nieuw-logo-zonder-mr-cash.avif?v=1781101920" alt="Bancontact" class="peptides-footer__pay-img">
      </div>
      <p class="peptides-footer__copyright">&copy; 2026 Peptidesmeester. Alle rechten voorbehouden.</p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [],
  "settings": [],
  "default": {}
}
{% endschema %}
