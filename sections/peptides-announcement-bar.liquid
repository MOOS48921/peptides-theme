{{ 'peptides-homepage.css' | asset_url | stylesheet_tag }}

<div class="peptides-announcement-bar">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
  {%- else -%}
    <p>{{ section.settings.text }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Peptides Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "default": "🇧🇪 Gratis verzending boven €250",
      "label": "Announcement text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    }
  ],
  "presets": [
    {
      "name": "Peptides Announcement Bar"
    }
  ]
}
{% endschema %}
