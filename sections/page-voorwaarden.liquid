{{ 'page-policy.css' | asset_url | stylesheet_tag }}
<style>body,#MainContent,main#MainContent{background-color:#111!important}</style>

<div class="policy-page page-width">
  <div class="policy-page__inner">

    <h1 class="policy-page__title">Algemene Voorwaarden</h1>
    <p class="policy-page__subtitle">Laatst bijgewerkt: januari 2025</p>

    <div class="policy-page__sections">

      <div class="policy-section">
        <h2 class="policy-section__heading">1. Algemeen</h2>
        <p class="policy-section__text">Deze algemene voorwaarden zijn van toepassing op alle aanbiedingen, bestellingen en overeenkomsten via onze website.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">2. Prijzen</h2>
        <p class="policy-section__text">Alle prijzen zijn in euro's en inclusief btw. Prijzen kunnen zonder voorafgaande kennisgeving worden gewijzigd.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">3. Bestellen</h2>
        <p class="policy-section__text">Door een bestelling te plaatsen, gaat u akkoord met deze algemene voorwaarden.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">4. Betaling</h2>
        <p class="policy-section__text">Betaling dient te worden voldaan vóór verzending. Wij accepteren diverse betaalmethoden waaronder iDEAL, creditcard en PayPal.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">5. Levering</h2>
        <p class="policy-section__text">Wij verzenden binnen 1–2 werkdagen. Levertijden zijn afhankelijk van uw locatie.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">6. Retourbeleid</h2>
        <p class="policy-section__text">Vanwege de aard van onze producten accepteren wij geen retourzendingen. Zie ons <a href="/pages/retourzendingen">retourbeleid</a> voor uitzonderingen.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">7. Aansprakelijkheid</h2>
        <p class="policy-section__text">Peptidesmeester is niet aansprakelijk voor schade voortvloeiend uit onjuist gebruik van onze producten.</p>
      </div>

      <div class="policy-section">
        <h2 class="policy-section__heading">8. Toepasselijk recht</h2>
        <p class="policy-section__text">Op deze voorwaarden is Nederlands recht van toepassing.</p>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Algemene Voorwaarden Page",
  "settings": [],
  "presets": [{ "name": "Algemene Voorwaarden Page" }]
}
{% endschema %}
