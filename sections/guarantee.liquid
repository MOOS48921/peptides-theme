<style>
.guarantee {
  background: #ffffff;
  padding: 80px 0;
  text-align: center;
}

.guarantee__inner {
  max-width: 640px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.guarantee__shield {
  width: 72px;
  height: 72px;
  background: #1a5c2e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guarantee__shield svg {
  width: 36px;
  height: 36px;
  fill: none;
  stroke: #ffffff;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.guarantee__eyebrow {
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #1a5c2e;
  margin: 0;
}

.guarantee__heading {
  font-size: clamp(2.4rem, 4vw, 3.6rem);
  font-weight: 800;
  color: #111111;
  margin: 0;
  line-height: 1.15;
  font-family: var(--font-heading-family, sans-serif);
}

.guarantee__subtext {
  font-size: 1.6rem;
  line-height: 1.7;
  color: #555555;
  margin: 0;
  max-width: 520px;
}

.guarantee__checks {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: center;
}

.guarantee__check {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.5rem;
  font-weight: 600;
  color: #111111;
}

.guarantee__check-icon {
  width: 22px;
  height: 22px;
  background: #1a5c2e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guarantee__check-icon svg {
  width: 12px;
  height: 12px;
  fill: none;
  stroke: #ffffff;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.guarantee__btn {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  background: #111111;
  color: #ffffff;
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1.4rem 3.2rem;
  border-radius: 50px;
  transition: background 0.2s ease, transform 0.2s ease;
  margin-top: 0.8rem;
}

.guarantee__btn:hover {
  background: #1a5c2e;
  transform: translateY(-1px);
}

.guarantee__btn svg {
  width: 18px;
  height: 18px;
  fill: none;
  stroke: #ffffff;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}
</style>

<div class="guarantee">
  <div class="guarantee__inner">

    <div class="guarantee__shield">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
    </div>

    <p class="guarantee__eyebrow">ONZE GARANTIE</p>

    <h2 class="guarantee__heading">Probeer Het, Risicoloos!</h2>

    <p class="guarantee__subtext">Ben je niet tevreden met ons product? Neem dan contact met ons op en we geven je een volledige, 100% probleemloze terugbetaling.</p>

    <div class="guarantee__checks">
      <div class="guarantee__check">
        <span class="guarantee__check-icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        100% Geld-Terug-Garantie
      </div>
      <div class="guarantee__check">
        <span class="guarantee__check-icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        Probleemloze Terugbetaling
      </div>
    </div>

    <a href="{{ section.settings.button_link }}" class="guarantee__btn">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z"/>
      </svg>
      Shop Risicoloos
    </a>

  </div>
</div>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Guarantee"
    }
  ]
}
{% endschema %}
