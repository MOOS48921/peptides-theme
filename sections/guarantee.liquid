<style>
.guarantee {
  background: transparent;
  padding: 60px 0;
}

.guarantee__inner {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 2rem;
}

.guarantee__card {
  background: #1a5c2e;
  border-radius: 16px;
  padding: 4rem 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  text-align: center;
}

.guarantee__shield {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.guarantee__shield svg {
  width: 64px;
  height: 64px;
  fill: none;
  stroke: #ffffff;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.guarantee__heading {
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 800;
  color: #ffffff;
  margin: 0;
  line-height: 1.2;
  font-family: var(--font-heading-family, sans-serif);
}

.guarantee__subtext {
  font-size: 1.5rem;
  line-height: 1.75;
  color: #ffffff;
  margin: 0;
  max-width: 620px;
}

.guarantee__btn {
  display: inline-block;
  background: #ffffff;
  color: #1a5c2e;
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1.4rem 3.6rem;
  border-radius: 50px;
  transition: opacity 0.2s ease, transform 0.2s ease;
  margin-top: 0.4rem;
}

.guarantee__btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.guarantee__checks {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rem;
}

.guarantee__check {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 1.4rem;
  font-weight: 600;
  color: #ffffff;
}

.guarantee__check svg {
  width: 18px;
  height: 18px;
  fill: none;
  stroke: #ffffff;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}
</style>

<div class="guarantee">
  <div class="guarantee__inner">
    <div class="guarantee__card">

      <div class="guarantee__shield">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
      </div>

      <h2 class="guarantee__heading">Probeer 90 Dagen Risicovrij</h2>

      <p class="guarantee__subtext">Bij Peptidesmeester zijn we trots om onze klanten een tevredenheidsgarantie van 90 dagen te bieden op al onze producten. Onze garantie geeft je drie maanden de tijd om zelf het effect van onze peptiden te testen. Als je na drie maanden niet tevreden bent met het resultaat betalen we het volledige bedrag terug. Zonder gedoe, beloofd.</p>

      <a href="{{ section.settings.button_link }}" class="guarantee__btn">PROBEER RISICOVRIJ</a>

      <div class="guarantee__checks">
        <div class="guarantee__check">
          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          100% Tevreden
        </div>
        <div class="guarantee__check">
          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Discreet Verpakt
        </div>
        <div class="guarantee__check">
          <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Gratis Retourneren
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Guarantee"
    }
  ]
}
{% endschema %}
