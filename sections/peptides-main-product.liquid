{%- comment -%} Embed full variants data for JS lookup {%- endcomment -%}
<script id="PeptidesVariantsData-{{ section.id }}" type="application/json">
  {{ product.variants | json }}
</script>

<script>
(function () {
  var SECTION = '{{ section.id }}';

  // Current selections: [option1Value, option2Value, option3Value, option4Value]
  // Pre-populate from the rendered button states (is-selected)
  var selected = [null, null, null, null];

  function init() {
    var section = document.getElementById('PeptidesProduct-' + SECTION);
    if (!section) return;

    // Read initial selections from rendered markup
    section.querySelectorAll('[data-option-group]').forEach(function (btn) {
      if (btn.classList.contains('is-selected')) {
        selected[parseInt(btn.dataset.optionGroup, 10)] = btn.dataset.optionValue;
      }
    });

    // Attach click handlers
    section.querySelectorAll('.peptides-option-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var groupIdx = parseInt(btn.dataset.optionGroup, 10);
        // Deselect siblings in same group
        section.querySelectorAll('[data-option-group="' + groupIdx + '"]').forEach(function (b) {
          b.classList.remove('is-selected');
          b.setAttribute('aria-pressed', 'false');
        });
        // Select clicked button
        btn.classList.add('is-selected');
        btn.setAttribute('aria-pressed', 'true');
        selected[groupIdx] = btn.dataset.optionValue;
        resolveVariant();
      });
    });

    resolveVariant();
  }

  function resolveVariant() {
    var variantsEl = document.getElementById('PeptidesVariantsData-' + SECTION);
    if (!variantsEl) return;

    var variants;
    try { variants = JSON.parse(variantsEl.textContent); } catch (e) { return; }

    // If product has no real variants (only default), don't try to match
    if (!variants || variants.length === 0) return;

    // Single default variant — no options to match against, just ensure button is enabled
    if (variants.length === 1 && variants[0].title === 'Default Title') {
      updateUI(variants[0]);
      return;
    }

    // Find variant matching all selected option values
    var match = null;
    for (var i = 0; i < variants.length; i++) {
      var v = variants[i];
      var opts = [v.option1, v.option2, v.option3, v.option4];
      var matches = true;
      for (var g = 0; g < 4; g++) {
        if (selected[g] === null) continue; // not yet selected, skip
        if (opts[g] !== null && opts[g] !== undefined && opts[g] !== selected[g]) {
          matches = false;
          break;
        }
      }
      if (matches) { match = v; break; }
    }

    updateUI(match);
  }

  function updateUI(variant) {
    var variantInput = document.getElementById('PeptidesVariantInput-' + SECTION);
    var btnText      = document.getElementById('PeptidesAddBtnText-' + SECTION);
    var submitBtn    = document.getElementById('ProductSubmitButton-' + SECTION);
    var priceEl      = document.getElementById('PeptidesPriceAmount-' + SECTION);
    var compareEl    = document.getElementById('PeptidesPriceCompare-' + SECTION);
    var stockText    = document.getElementById('PeptidesStockText-' + SECTION);
    var stockBadge   = document.getElementById('PeptidesStock-' + SECTION);

    if (variant) {
      if (variantInput) variantInput.value = variant.id;

      var available = variant.available;
      if (submitBtn) submitBtn.disabled = !available;
      if (btnText)   btnText.textContent = available ? 'In winkelwagen' : 'Uitverkocht';

      if (stockText) stockText.textContent = available ? 'Op voorraad' : 'Uitverkocht';
      if (stockBadge) {
        stockBadge.style.color = available ? '#1B6B3A' : '#888';
        var icon = stockBadge.querySelector('.peptides-product__stock-icon');
        if (icon) icon.style.background = available ? '#1B6B3A' : '#aaa';
      }

      var fmt = (window.Shopify && window.Shopify.money_format) || '€{{amount}}';
      if (priceEl) priceEl.textContent = formatMoney(variant.price, fmt);
      if (compareEl) {
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          compareEl.textContent = formatMoney(variant.compare_at_price, fmt);
          compareEl.hidden = false;
        } else {
          compareEl.hidden = true;
        }
      }
    } else {
      // No matching variant found — disable button
      if (submitBtn) submitBtn.disabled = true;
      if (btnText)   btnText.textContent = 'Niet beschikbaar';
    }
  }

  function formatMoney(cents, fmt) {
    var amount = (cents / 100).toFixed(2);
    var amountComma = amount.replace('.', ',');
    return fmt
      .replace('{{amount}}', amount)
      .replace('{{amount_no_decimals}}', Math.round(cents / 100))
      .replace('{{amount_with_comma_separator}}', amountComma)
      .replace('{{amount_no_decimals_with_comma_separator}}', String(Math.round(cents / 100)));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === SECTION) init();
  });
})();
</script>

