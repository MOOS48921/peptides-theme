<script>
(function () {
  function initAccordions(root) {
    root.querySelectorAll('[data-accordion]').forEach(function (acc) {
      var btn  = acc.querySelector('.peptides-accordion__trigger');
      var body = acc.querySelector('.peptides-accordion__body');
      if (!btn || !body) return;

      btn.addEventListener('click', function () {
        var open = btn.getAttribute('aria-expanded') === 'true';
        // Close all other accordions in the same panel container
        var container = acc.closest('.peptides-dark-panels');
        if (container) {
          container.querySelectorAll('[data-accordion]').forEach(function (other) {
            if (other === acc) return;
            var ob = other.querySelector('.peptides-accordion__trigger');
            var ob2 = other.querySelector('.peptides-accordion__body');
            if (ob) ob.setAttribute('aria-expanded', 'false');
            if (ob2) ob2.hidden = true;
            other.classList.remove('peptides-accordion--open');
          });
        }
        // Toggle this one
        var nowOpen = !open;
        btn.setAttribute('aria-expanded', String(nowOpen));
        body.hidden = !nowOpen;
        acc.classList.toggle('peptides-accordion--open', nowOpen);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAccordions(document); });
  } else {
    initAccordions(document);
  }
  document.addEventListener('shopify:section:load', function (e) {
    var el = e.target || document;
    initAccordions(el);
  });
})();
</script>
