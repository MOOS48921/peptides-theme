{% comment %}
  Peptides Meester – custom product section (v2)
  Two-column layout: image left, options + buy right.
  Option groups are hardcoded for the Retatrutide product.
  JS reads product.variants JSON to find the matching variant
  when options are selected, falling back gracefully when no
  variants are configured yet.
{% endcomment %}

{{ 'peptides-product.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- assign product_form_id = 'product-form-' | append: section.id -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%}
  Determine button state from product.available (not variant.available)
  so a product marked in-stock always shows "In winkelwagen" even when
  no real variants exist yet.
{%- endcomment -%}
{%- assign btn_available = product.available -%}
{%- if current_variant != null and product.variants.size > 0 -%}
  {%- assign btn_available = current_variant.available -%}
{%- endif -%}

<section
  id="PeptidesProduct-{{ section.id }}"
  class="peptides-product page-width"
  data-section="{{ section.id }}"
>
  <div class="peptides-product__grid">

    {%- comment -%} ── Left: product image ─────────────────────────── {%- endcomment -%}
    <div class="peptides-product__media">
      {%- if product.featured_media -%}
        <img
          src="{{ product.featured_media | image_url: width: 800 }}"
          alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
          width="{{ product.featured_media.width }}"
          height="{{ product.featured_media.height }}"
          class="peptides-product__image"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <div class="peptides-product__image-placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Right: product info ─────────────────────────── {%- endcomment -%}
    <div class="peptides-product__info">

      <h1 class="peptides-product__title">{{ product.title | escape }}</h1>

      {%- comment -%} Stock indicator — driven by JS once variant is resolved {%- endcomment -%}
      <div class="peptides-product__stock" id="PeptidesStock-{{ section.id }}" role="status">
        <span class="peptides-product__stock-icon" aria-hidden="true">
          <svg viewBox="0 0 10 8" xmlns="http://www.w3.org/2000/svg">
            <polyline points="1,4 4,7 9,1"/>
          </svg>
        </span>
        <span id="PeptidesStockText-{{ section.id }}">Op voorraad</span>
      </div>

      {%- comment -%}
        ── Hardcoded option button groups ──────────────────────────
        These always render. JS maps the selection to a variant ID.
        The data-option-index must match the option position in Shopify
        (option1 → 0, option2 → 1, etc.) once variants are configured.
      {%- endcomment -%}

      {%- comment -%} Option 1 – Concentratie {%- endcomment -%}
      <div class="peptides-variant-group" data-option-index="0">
        <span class="peptides-variant-group__label">Concentratie (mg)</span>
        <div class="peptides-variant-group__buttons" role="group" aria-label="Concentratie (mg)">
          {%- assign concentraties = '10mg,20mg,30mg,40mg,60mg' | split: ',' -%}
          {%- for val in concentraties -%}
            <button
              type="button"
              class="peptides-option-btn{% if forloop.first %} is-selected{% endif %}"
              data-option-group="0"
              data-option-value="{{ val }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            >{{ val }}</button>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Option 2 – Bacteriostatisch Water {%- endcomment -%}
      <div class="peptides-variant-group" data-option-index="1">
        <span class="peptides-variant-group__label">Bacteriostatisch Water</span>
        <div class="peptides-variant-group__buttons" role="group" aria-label="Bacteriostatisch Water">
          <button type="button" class="peptides-option-btn" data-option-group="1" data-option-value="10ml" aria-pressed="false">10ml</button>
          <button type="button" class="peptides-option-btn is-selected" data-option-group="1" data-option-value="3ml standaard inbegrepen" aria-pressed="true">3ml <span style="font-size:1.1rem;opacity:.75">(standaard inbegrepen)</span></button>
        </div>
      </div>

      {%- comment -%} Option 3 – Insulinenaalden {%- endcomment -%}
      <div class="peptides-variant-group" data-option-index="2">
        <span class="peptides-variant-group__label">Insulinenaalden</span>
        <div class="peptides-variant-group__buttons" role="group" aria-label="Insulinenaalden">
          <button type="button" class="peptides-option-btn" data-option-group="2" data-option-value="10x 1ml insulinenaalden" aria-pressed="false">10× 1ml insulinenaalden</button>
          <button type="button" class="peptides-option-btn" data-option-group="2" data-option-value="10x 0.5ml insulinenaalden" aria-pressed="false">10× 0,5ml insulinenaalden</button>
          <button type="button" class="peptides-option-btn is-selected" data-option-group="2" data-option-value="Geen" aria-pressed="true">Geen</button>
        </div>
      </div>

      {%- comment -%} Option 4 – Alcohol Swabs {%- endcomment -%}
      <div class="peptides-variant-group" data-option-index="3">
        <span class="peptides-variant-group__label">Alcohol Swabs</span>
        <div class="peptides-variant-group__buttons" role="group" aria-label="Alcohol Swabs">
          <button type="button" class="peptides-option-btn" data-option-group="3" data-option-value="Ja" aria-pressed="false">Ja</button>
          <button type="button" class="peptides-option-btn is-selected" data-option-group="3" data-option-value="Nee" aria-pressed="true">Nee</button>
        </div>
      </div>

      {%- comment -%} Price row {%- endcomment -%}
      <div class="peptides-product__price-row" id="PeptidesPrice-{{ section.id }}" role="status">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="peptides-product__price-compare" id="PeptidesPriceCompare-{{ section.id }}">
            {{ current_variant.compare_at_price | money }}
          </span>
        {%- else -%}
          <span class="peptides-product__price-compare" id="PeptidesPriceCompare-{{ section.id }}" hidden></span>
        {%- endif -%}
        <span class="peptides-product__price" id="PeptidesPriceAmount-{{ section.id }}">
          {%- if current_variant.price -%}
            {{ current_variant.price | money }}
          {%- elsif product.price_min -%}
            {{ product.price_min | money }}
          {%- endif -%}
        </span>
      </div>

      {%- comment -%} Add to cart form {%- endcomment -%}
      <product-form
        class="product-form"
        data-hide-errors="false"
        data-section-id="{{ section.id }}"
      >
        <div class="product-form__error-message-wrapper peptides-product__form-error" role="alert" hidden>
          <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
          <span class="product-form__error-message"></span>
        </div>

        {%- form 'product',
          product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input
            type="hidden"
            name="id"
            value="{{ current_variant.id | default: product.variants.first.id }}"
            class="product-variant-id"
            id="PeptidesVariantInput-{{ section.id }}"
          >

          <button
            id="ProductSubmitButton-{{ section.id }}"
            type="submit"
            name="add"
            class="peptides-product__add-btn"
            {% unless btn_available %}disabled{% endunless %}
          >
            <span id="PeptidesAddBtnText-{{ section.id }}">
              {%- if btn_available -%}
                In winkelwagen
              {%- else -%}
                Uitverkocht
              {%- endif -%}
            </span>
            {%- render 'loading-spinner' -%}
          </button>
        {%- endform -%}
      </product-form>

      {%- comment -%} ── Trust / payment block ────────────────────── {%- endcomment -%}
      <div class="peptides-trust">

        {%- comment -%} Section 1 – Payment methods {%- endcomment -%}
        <div class="peptides-trust__payments">
          <div class="peptides-trust__payments-header">
            <span class="peptides-trust__lock-icon" aria-hidden="true">
              <svg width="14" height="16" viewBox="0 0 14 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="7" width="12" height="9" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M4 7V4.5a3 3 0 0 1 6 0V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="peptides-trust__payments-label">Veilige betalingen</span>
          </div>
          <div class="peptides-trust__payment-icons" aria-label="Geaccepteerde betaalmethoden">

            {%- comment -%} Visa {%- endcomment -%}
            <span class="peptides-pay-badge" title="Visa" style="background:#1A1F71;">
              <svg viewBox="0 0 80 30" xmlns="http://www.w3.org/2000/svg" aria-label="Visa" role="img" height="30" width="60">
                <text x="50%" y="21" font-family="Arial,Helvetica,sans-serif" font-size="16" font-weight="bold" font-style="italic" fill="#fff" text-anchor="middle" letter-spacing="1">VISA</text>
              </svg>
            </span>

            {%- comment -%} Mastercard {%- endcomment -%}
            <span class="peptides-pay-badge" title="Mastercard" style="background:#fff;">
              <svg viewBox="0 0 50 30" xmlns="http://www.w3.org/2000/svg" aria-label="Mastercard" role="img" height="30" width="50">
                <circle cx="19" cy="15" r="10" fill="#EB001B"/>
                <circle cx="31" cy="15" r="10" fill="#F79E1B"/>
                <path d="M25 7.3A10 10 0 0 1 29.3 15 10 10 0 0 1 25 22.7 10 10 0 0 1 20.7 15 10 10 0 0 1 25 7.3z" fill="#FF5F00"/>
              </svg>
            </span>

            {%- comment -%} PayPal {%- endcomment -%}
            <span class="peptides-pay-badge" title="PayPal" style="background:#fff;">
              <svg viewBox="0 0 80 30" xmlns="http://www.w3.org/2000/svg" aria-label="PayPal" role="img" height="30" width="70">
                <text x="50%" y="20" font-family="Arial,Helvetica,sans-serif" font-size="13" font-weight="bold" fill="#003087" text-anchor="middle">Pay</text>
                <text x="50%" y="20" font-family="Arial,Helvetica,sans-serif" font-size="13" font-weight="bold" fill="#009CDE" text-anchor="middle" dx="18">Pal</text>
              </svg>
            </span>

            {%- comment -%} Apple Pay {%- endcomment -%}
            <span class="peptides-pay-badge" title="Apple Pay" style="background:#000;">
              <svg viewBox="0 0 80 30" xmlns="http://www.w3.org/2000/svg" aria-label="Apple Pay" role="img" height="30" width="70">
                <path d="M22 8.5c1-.1 1.9.6 2.4 1.3-.5.4-1.5 1.1-1.5 2.3 0 1.4 1.2 1.9 1.2 1.9s-.8 2.4-2 3.5c-.7.8-1.5 1.6-2.4 1.6-.9 0-1.1-.5-2.1-.5-1 0-1.4.5-2.2.5-.9 0-1.7-.8-2.4-1.6-1.3-1.5-2.4-4-2.4-6.3 0-2.9 1.9-4.4 3.8-4.4.9 0 1.7.6 2.3.6.6 0 1.5-.6 2.5-.6.4 0 1.4.1 2.2.6.1 0 .6.1.6.1zm-2.7-1.7c.4-.5.8-1.2.7-1.9-.6.1-1.4.4-1.8.9-.4.4-.8 1.1-.7 1.8.7.1 1.4-.3 1.8-.8z" fill="#fff"/>
                <text x="38" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="600" fill="#fff" text-anchor="middle">Pay</text>
              </svg>
            </span>

            {%- comment -%} iDEAL {%- endcomment -%}
            <span class="peptides-pay-badge" title="iDEAL" style="background:#fff;">
              <svg viewBox="0 0 70 30" xmlns="http://www.w3.org/2000/svg" aria-label="iDEAL" role="img" height="30" width="60">
                <rect width="70" height="30" rx="0" fill="#fff"/>
                <rect x="0" y="0" width="18" height="30" fill="#CC0066"/>
                <text x="9" y="21" font-family="Arial,Helvetica,sans-serif" font-size="15" font-weight="900" fill="#fff" text-anchor="middle">i</text>
                <text x="42" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="bold" fill="#000" text-anchor="middle">DEAL</text>
              </svg>
            </span>

            {%- comment -%} Bancontact {%- endcomment -%}
            <span class="peptides-pay-badge" title="Bancontact" style="background:#005498;">
              <svg viewBox="0 0 90 30" xmlns="http://www.w3.org/2000/svg" aria-label="Bancontact" role="img" height="30" width="80">
                <text x="50%" y="20" font-family="Arial,Helvetica,sans-serif" font-size="11" font-weight="bold" fill="#fff" text-anchor="middle">bancontact</text>
              </svg>
            </span>

          </div>
        </div>

        {%- comment -%} Section 2 – USP bullets {%- endcomment -%}
        <ul class="peptides-trust__usps" aria-label="Voordelen">
          <li>
            <span class="peptides-trust__usp-check" aria-hidden="true">
              <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polyline points="1,5 4.5,8.5 11,1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            Levering binnen 1-2 werkdagen
          </li>
          <li>
            <span class="peptides-trust__usp-check" aria-hidden="true">
              <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polyline points="1,5 4.5,8.5 11,1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            Ophalen bij afhaalpunt beschikbaar
          </li>
          <li>
            <span class="peptides-trust__usp-check" aria-hidden="true">
              <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polyline points="1,5 4.5,8.5 11,1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            Discreet verpakt
          </li>
        </ul>

        {%- comment -%} Section 3 – Delivery timeline widget {%- endcomment -%}
        <div class="peptides-delivery">
          <div class="peptides-delivery__header">
            <p class="peptides-delivery__headline">Bestel voor 14:00 voor verzending op dezelfde dag</p>
            <p class="peptides-delivery__subtext">Bestel nu, verzendt volgende werkdag</p>
          </div>

          <div class="peptides-delivery__timeline">
            {%- comment -%} Step 1 – Besteld (gold/active) {%- endcomment -%}
            <div class="peptides-delivery__step peptides-delivery__step--active">
              <div class="peptides-delivery__step-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="3,9 7.5,13.5 15,4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="peptides-delivery__step-line" aria-hidden="true"></div>
              <p class="peptides-delivery__step-label">Besteld</p>
              <p class="peptides-delivery__step-date">Morgen</p>
            </div>

            {%- comment -%} Step 2 – Verzonden {%- endcomment -%}
            <div class="peptides-delivery__step">
              <div class="peptides-delivery__step-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="1" y="4" width="11" height="9" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
                  <path d="M12 7.5h3l2 3V13h-5V7.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                  <circle cx="4" cy="13.5" r="1.5" fill="currentColor"/>
                  <circle cx="14" cy="13.5" r="1.5" fill="currentColor"/>
                </svg>
              </div>
              <div class="peptides-delivery__step-line" aria-hidden="true"></div>
              <p class="peptides-delivery__step-label">Verzonden</p>
              <p class="peptides-delivery__step-date">11 juni</p>
            </div>

            {%- comment -%} Step 3 – Geleverd {%- endcomment -%}
            <div class="peptides-delivery__step">
              <div class="peptides-delivery__step-icon">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 2L2 6v6l7 4 7-4V6L9 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                  <path d="M2 6l7 4 7-4" stroke="currentColor" stroke-width="1.6"/>
                  <line x1="9" y1="10" x2="9" y2="16" stroke="currentColor" stroke-width="1.6"/>
                </svg>
              </div>
              <p class="peptides-delivery__step-label">Geleverd</p>
              <p class="peptides-delivery__step-date">12 juni</p>
            </div>
          </div>

          <div class="peptides-delivery__country">
            <span class="peptides-delivery__flag" aria-hidden="true">🇳🇱</span>
            <select class="peptides-delivery__country-select" aria-label="Land selecteren">
              <option value="NL" selected>Netherlands</option>
              <option value="BE">Belgium</option>
              <option value="DE">Germany</option>
              <option value="FR">France</option>
            </select>
            <span class="peptides-delivery__select-caret" aria-hidden="true">
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>

      </div>
      {%- comment -%} end .peptides-trust {%- endcomment -%}

      {%- comment -%} Description moved into PRODUCTBESCHRIJVING accordion below {%- endcomment -%}

    </div>
  </div>
</section>

{%- comment -%} ── Dark info panels (full-width, below two-column grid) ─────── {%- endcomment -%}
<div class="peptides-dark-panels page-width" id="PeptidesPanels-{{ section.id }}">

  {%- comment -%} Section 1 – Productbeschrijving accordion (open by default) {%- endcomment -%}
  <div class="peptides-accordion" data-accordion>
    <button class="peptides-accordion__trigger" aria-expanded="false" aria-controls="acc-desc-{{ section.id }}">
      <span class="peptides-accordion__title">PRODUCTBESCHRIJVING</span>
      <span class="peptides-accordion__caret" aria-hidden="true">
        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>
    <div class="peptides-accordion__body" id="acc-desc-{{ section.id }}" hidden>
      <div class="peptides-accordion__content rte">
        {%- if product.description != blank -%}
          {{ product.description }}
        {%- else -%}
          <p>Productbeschrijving volgt binnenkort.</p>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} Section 2 – Verzending accordion (closed by default) {%- endcomment -%}
  {%- capture check_svg -%}
    <svg width="10" height="9" viewBox="0 0 10 9" fill="none" xmlns="http://www.w3.org/2000/svg"><polyline points="1,4.5 3.8,7.5 9,1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- endcapture -%}
  <div class="peptides-accordion" data-accordion>
    <button class="peptides-accordion__trigger" aria-expanded="false" aria-controls="acc-ship-{{ section.id }}">
      <span class="peptides-accordion__title">VERZENDING &amp; LEVERING</span>
      <span class="peptides-accordion__caret" aria-hidden="true">
        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>
    <div class="peptides-accordion__body" id="acc-ship-{{ section.id }}" hidden>
      <div class="peptides-accordion__content">
        <ul class="peptides-shipping-info__list">
          <li>
            <span class="peptides-shipping-info__check" aria-hidden="true">{{ check_svg }}</span>
            <span><strong>Nederland:</strong> gratis verzending</span>
          </li>
          <li>
            <span class="peptides-shipping-info__check" aria-hidden="true">{{ check_svg }}</span>
            <span><strong>België:</strong> gratis verzending</span>
          </li>
          <li>
            <span class="peptides-shipping-info__check" aria-hidden="true">{{ check_svg }}</span>
            <span><strong>Duitsland:</strong> 3-7 werkdagen, €9,95</span>
          </li>
          <li>
            <span class="peptides-shipping-info__check" aria-hidden="true">{{ check_svg }}</span>
            <span><strong>Rest van Europa:</strong> 3-7 werkdagen, €14,95</span>
          </li>
          <li>
            <span class="peptides-shipping-info__check" aria-hidden="true">{{ check_svg }}</span>
            <span>Verzending vanuit Nederland · Discrete verpakking · Track &amp; trace inbegrepen</span>
          </li>
          <li>
            <span class="peptides-shipping-info__check" aria-hidden="true">{{ check_svg }}</span>
            <span>Gratis verzending vanaf €250</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  {%- comment -%} Section 3 – Labresultaten accordion (closed by default) {%- endcomment -%}
  <div class="peptides-accordion" data-accordion>
    <button class="peptides-accordion__trigger" aria-expanded="false" aria-controls="acc-lab-{{ section.id }}">
      <span class="peptides-accordion__title">LABRESULTATEN</span>
      <span class="peptides-accordion__caret" aria-hidden="true">
        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>
    <div class="peptides-accordion__body" id="acc-lab-{{ section.id }}" hidden>
      <div class="peptides-accordion__content">
        <table class="peptides-lab__table">
          <tbody>
            <tr>
              <td>Testtype</td>
              <td class="peptides-lab__value">
                {%- if product.metafields.custom.testtype != blank -%}
                  {{ product.metafields.custom.testtype.value }}
                {%- else -%}
                  Resultaat
                {%- endif -%}
              </td>
            </tr>
            <tr>
              <td>Verificatie</td>
              <td>
                {%- if product.metafields.custom.testrapport_url != blank -%}
                  <a href="{{ product.metafields.custom.testrapport_url.value }}" class="peptides-lab__link" target="_blank" rel="noopener">Testrapport verifiëren</a>
                {%- else -%}
                  <span class="peptides-lab__link">Testrapport verifiëren</span>
                {%- endif -%}
              </td>
            </tr>
          </tbody>
        </table>
        <a
