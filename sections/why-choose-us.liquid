{{ 'why-choose-us.css' | asset_url | stylesheet_tag }}

<section class="why-choose-us">
  <div class="why-choose-us__inner page-width">

    <h2 class="why-choose-us__heading">{{ section.settings.heading }}</h2>

    <div class="why-choose-us__subtext">
      <p>{{ section.settings.paragraph_1 }}</p>
      <p>{{ section.settings.paragraph_2 }}</p>
    </div>

    <div class="why-choose-us__grid">

      {%- comment -%} USP 1 – Laboratorium Getest {%- endcomment -%}
      <div class="why-choose-us__card">
        <div class="why-choose-us__icon-wrap" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z" stroke="#F5C518" stroke-width="2" stroke-linejoin="round"/>
            <path d="M9 12l2 2 4-4" stroke="#F5C518" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="why-choose-us__card-title">{{ section.settings.usp1_title }}</h3>
        <p class="why-choose-us__card-text">{{ section.settings.usp1_text }}</p>
      </div>

      {%- comment -%} USP 2 – Verzending dezelfde dag {%- endcomment -%}
      <div class="why-choose-us__card">
        <div class="why-choose-us__icon-wrap" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 3h13v13H1V3z" stroke="#F5C518" stroke-width="2" stroke-linejoin="round"/>
            <path d="M14 8h4l3 3v5h-7V8z" stroke="#F5C518" stroke-width="2" stroke-linejoin="round"/>
            <circle cx="5.5" cy="18.5" r="2.5" stroke="#F5C518" stroke-width="2"/>
            <circle cx="18.5" cy="18.5" r="2.5" stroke="#F5C518" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="why-choose-us__card-title">{{ section.settings.usp2_title }}</h3>
        <p class="why-choose-us__card-text">{{ section.settings.usp2_text }}</p>
      </div>

      {%- comment -%} USP 3 – Gebruiksrichtlijnen {%- endcomment -%}
      <div class="why-choose-us__card">
        <div class="why-choose-us__icon-wrap" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke="#F5C518" stroke-width="2"/>
            <circle cx="12" cy="12" r="3" stroke="#F5C518" stroke-width="2"/>
            <line x1="12" y1="2" x2="12" y2="5" stroke="#F5C518" stroke-width="2" stroke-linecap="round"/>
            <line x1="12" y1="19" x2="12" y2="22" stroke="#F5C518" stroke-width="2" stroke-linecap="round"/>
            <line x1="2" y1="12" x2="5" y2="12" stroke="#F5C518" stroke-width="2" stroke-linecap="round"/>
            <line x1="19" y1="12" x2="22" y2="12" stroke="#F5C518" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="why-choose-us__card-title">{{ section.settings.usp3_title }}</h3>
        <p class="why-choose-us__card-text">{{ section.settings.usp3_text }}</p>
      </div>

      {%- comment -%} USP 4 – Klantenservice {%- endcomment -%}
      <div class="why-choose-us__card">
        <div class="why-choose-us__icon-wrap" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="9" cy="7" r="3" stroke="#F5C518" stroke-width="2"/>
            <path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" stroke="#F5C518" stroke-width="2" stroke-linecap="round"/>
            <circle cx="17" cy="7" r="2" stroke="#F5C518" stroke-width="2"/>
            <path d="M21 21v-1.5A3 3 0 0 0 18 16.5" stroke="#F5C518" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="why-choose-us__card-title">{{ section.settings.usp4_title }}</h3>
        <p class="why-choose-us__card-text">{{ section.settings.usp4_text }}</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WAAROM ONDERZOEKERS KIEZEN VOOR PEPTIDESMEESTER"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Wij leveren in Europa geproduceerde peptiden met een geverifieerde zuiverheid van ≥99%. Elke batch wordt onafhankelijk getest en wordt geleverd met een Certificaat van Analyse."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Word lid van onze Telegram-community voor exclusieve aanbiedingen, onderzoeksupdates en directe ondersteuning van ons team."
    },
    {
      "type": "header",
      "content": "USP 1"
    },
    {
      "type": "text",
      "id": "usp1_title",
      "label": "Title",
      "default": "Laboratorium Getest"
    },
    {
      "type": "text",
      "id": "usp1_text",
      "label": "Subtext",
      "default": "Alle producten getest op zuiverheid en kwaliteit"
    },
    {
      "type": "header",
      "content": "USP 2"
    },
    {
      "type": "text",
      "id": "usp2_title",
      "label": "Title",
      "default": "Verzending dezelfde dag"
    },
    {
      "type": "text",
      "id": "usp2_text",
      "label": "Subtext",
      "default": "Snelle levering door heel Europa"
    },
    {
      "type": "header",
      "content": "USP 3"
    },
    {
      "type": "text",
      "id": "usp3_title",
      "label": "Title",
      "default": "Gebruiksrichtlijnen"
    },
    {
      "type": "text",
      "id": "usp3_text",
      "label": "Subtext",
      "default": "Deskundig advies over productbehandeling"
    },
    {
      "type": "header",
      "content": "USP 4"
    },
    {
      "type": "text",
      "id": "usp4_title",
      "label": "Title",
      "default": "Klantenservice"
    },
    {
      "type": "text",
      "id": "usp4_text",
      "label": "Subtext",
      "default": "Toegewijde ondersteuning voor al uw vragen"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us"
    }
  ]
}
{% endschema %}
